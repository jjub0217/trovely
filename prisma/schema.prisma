generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReelSource {
  instagram
  youtube
}

model Reel {
  id         String         @id @default(cuid())
  url        String
  thumbnail  String?
  memo       String?
  review     String?
  visited    Boolean        @default(false)
  source     ReelSource     @default(instagram)
  userId     String
  categories ReelCategory[]
  tags       ReelTag[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([url, userId])
  @@index([userId])
}

model Category {
  id     String         @id @default(cuid())
  name   String
  userId String
  reels  ReelCategory[]

  @@unique([name, userId])
  @@index([userId])
}

model ReelCategory {
  reelId     String
  categoryId String
  reel       Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([reelId, categoryId])
}

model Tag {
  id     String    @id @default(cuid())
  name   String
  userId String
  reels  ReelTag[]

  @@unique([name, userId])
  @@index([userId])
}

model AdminRole {
  userId String @id
  email  String
  createdAt DateTime @default(now())
}

model Withdrawal {
  id        String   @id @default(cuid())
  email     String
  reason    String
  detail    String?
  createdAt DateTime @default(now())
}

model ReelTag {
  reelId String
  tagId  String
  reel   Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reelId, tagId])
}
